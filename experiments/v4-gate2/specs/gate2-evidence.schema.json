    "scenario17": {"allOf": [{"$ref": "#/$defs/scenarioResult"}, {"properties": {"scenario_id": {"const": "G2-S17-DISTINCT-EXECUTOR"}}}]},
    "scenario18": {"allOf": [{"$ref": "#/$defs/scenarioResult"}, {"properties": {"scenario_id": {"const": "G2-S18-LIVE-OVERLAP"}}}]},
    "scenario19": {"allOf": [{"$ref": "#/$defs/scenarioResult"}, {"properties": {"scenario_id": {"const": "G2-S19-COMPLETE-EVIDENCE"}}}]},
    "orderingEvidenceType": {"type": "string", "enum": ["CONSENSUS_HEIGHT", "FINALIZATION_HEIGHT", "TRANSACTION_ORDER_INDEX", "HISTORICAL_STATUS", "REEXECUTION_TRACE", "CONFLICT_TRACE", "UNAVAILABLE"]},
    "overlapTrial": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trial_id", "predeclared_index", "deployment_address", "deployment_transaction_hash", "old_attempt_id", "successor_attempt_id", "old_execution_hash", "invalidation_hash", "retry_hash", "old_execution_path_entered", "authoritative_ordering_evidence_type", "authoritative_ordering_evidence", "ordering_achieved", "before_state", "successor_authoritative_state", "after_old_execution_state", "allowed_mutations", "observed_mutations", "mandatory_assertions", "trial_status", "trial_reason_code"],
      "properties": {
        "trial_id": {"type": "string"},
        "predeclared_index": {"type": "integer", "minimum": 1, "maximum": 3},
        "deployment_address": {"anyOf": [{"$ref": "#/$defs/address"}, {"type": "null"}]},
        "deployment_transaction_hash": {"anyOf": [{"$ref": "#/$defs/transactionHash"}, {"type": "null"}]},
        "old_attempt_id": {"anyOf": [{"$ref": "#/$defs/positiveSafeInteger"}, {"type": "null"}]},
        "successor_attempt_id": {"anyOf": [{"$ref": "#/$defs/positiveSafeInteger"}, {"type": "null"}]},
        "old_execution_hash": {"anyOf": [{"$ref": "#/$defs/transactionHash"}, {"type": "null"}]},
        "invalidation_hash": {"anyOf": [{"$ref": "#/$defs/transactionHash"}, {"type": "null"}]},
        "retry_hash": {"anyOf": [{"$ref": "#/$defs/transactionHash"}, {"type": "null"}]},
        "old_execution_path_entered": {"type": "boolean"},
        "authoritative_ordering_evidence_type": {"$ref": "#/$defs/orderingEvidenceType"},
        "authoritative_ordering_evidence": {"type": "object", "propertyNames": {"pattern": "^(?!(private_key|privateKey|mnemonic|seed|secret|raw_signed_transaction|authorization)$).+$"}, "additionalProperties": {"$ref": "#/$defs/safeJsonValue"}},
        "ordering_achieved": {"type": "boolean"},
        "before_state": {"anyOf": [{"$ref": "#/$defs/snapshot"}, {"type": "null"}]},
        "successor_authoritative_state": {"anyOf": [{"$ref": "#/$defs/snapshot"}, {"type": "null"}]},
        "after_old_execution_state": {"anyOf": [{"$ref": "#/$defs/snapshot"}, {"type": "null"}]},
        "allowed_mutations": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "observed_mutations": {"type": "array", "items": {"$ref": "#/$defs/mutation"}},
        "mandatory_assertions": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "prefixItems": [
            {"allOf": [{"$ref": "#/$defs/assertionClaim"}, {"properties": {"id": {"const": "ORDERING_PROVED"}}}]},
            {"allOf": [{"$ref": "#/$defs/assertionClaim"}, {"properties": {"id": {"const": "OLD_PATH_ENTERED"}}}]},
            {"allOf": [{"$ref": "#/$defs/assertionClaim"}, {"properties": {"id": {"const": "NO_STALE_MUTATION"}}}]},
            {"allOf": [{"$ref": "#/$defs/assertionClaim"}, {"properties": {"id": {"const": "SUCCESSOR_REMAINS_EXECUTABLE"}}}]},
            {"allOf": [{"$ref": "#/$defs/assertionClaim"}, {"properties": {"id": {"const": "SUCCESSOR_STATE_UNCHANGED"}}}]},
            {"allOf": [{"$ref": "#/$defs/assertionClaim"}, {"properties": {"id": {"const": "FINAL_STATE_STABLE"}}}]}
          ],
          "items": false
        },
        "trial_status": {"$ref": "#/$defs/trialStatus"},
        "trial_reason_code": {"type": "string", "minLength": 1}
      },
      "allOf": [
        {"if": {"properties": {"trial_status": {"const": "PASS"}}, "required": ["trial_status"]}, "then": {"properties": {"trial_reason_code": {"$ref": "#/$defs/passReason"}, "ordering_achieved": {"const": true}, "old_execution_path_entered": {"const": true}, "authoritative_ordering_evidence_type": {"not": {"const": "UNAVAILABLE"}}, "authoritative_ordering_evidence": {"type": "object", "minProperties": 1}, "old_execution_hash": {"$ref": "#/$defs/transactionHash"}, "before_state": {"$ref": "#/$defs/snapshot"}, "successor_authoritative_state": {"$ref": "#/$defs/snapshot"}, "after_old_execution_state": {"$ref": "#/$defs/snapshot"}, "allowed_mutations": {"type": "array", "maxItems": 0}, "observed_mutations": {"type": "array", "maxItems": 0}}}},
        {"if": {"properties": {"trial_status": {"const": "FAIL"}}, "required": ["trial_status"]}, "then": {"properties": {"trial_reason_code": {"$ref": "#/$defs/failReason"}, "ordering_achieved": {"const": true}, "observed_mutations": {"type": "array", "minItems": 1}}}},
        {"if": {"properties": {"trial_status": {"const": "INCONCLUSIVE"}}, "required": ["trial_status"]}, "then": {"properties": {"trial_reason_code": {"$ref": "#/$defs/inconclusiveReason"}}}},
        {"if": {"properties": {"trial_status": {"const": "NOT_RUN"}}, "required": ["trial_status"]}, "then": {"properties": {"trial_reason_code": {"$ref": "#/$defs/notRunReason"}}}},
        {"if": {"properties": {"authoritative_ordering_evidence_type": {"const": "UNAVAILABLE"}}, "required": ["authoritative_ordering_evidence_type"]}, "then": {"properties": {"ordering_achieved": {"const": false}, "trial_status": {"enum": ["INCONCLUSIVE", "NOT_RUN"]}}}}
      ]
    }
  }
}
